# API KEYS (LiteLLM tự động sử dụng dựa trên prefix model)
OPENAI_API_KEY=sk-proj-xxxx
GOOGLE_API_KEY=AIzaSyxxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
GROQ_API_KEY=gsk_xxxx

# AGENT CONFIG
SUPERVISOR_PROVIDER=openai
SUPERVISOR_MODEL=gpt-4o-mini

RETRIEVAL_PROVIDER=openai
RETRIEVAL_MODEL=text-embedding-3-small

POLICY_PROVIDER=openai
POLICY_MODEL=gpt-4o-mini

SYNTHESIS_PROVIDER=openai
SYNTHESIS_MODEL=gpt-4o-mini

# LLM JUDGE CONFIG (Đánh giá đa mô hình)
JUDGE_1_PROVIDER=openai
JUDGE_1_MODEL=gpt-4o-mini

JUDGE_2_PROVIDER=gemini
JUDGE_2_MODEL=gemini-3.1-flash-lite-preview

# DATABASE CONFIG
CHROMA_DB_PATH=./data/chroma_db
COLLECTION_NAME=rag_lab

# SYSTEM SETTINGS
LLM_TEMPERATURE=0
RETRIEVAL_TOP_K=3
BATCH_SIZE=5

# OBSERVABILITY
TRACE_OUTPUT_DIR=./artifacts/traces
SAVE_TRACE=true
