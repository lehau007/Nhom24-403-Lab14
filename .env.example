GEMINI_API_KEY=your_google_genai_api_key

# Vector store
CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION=policy_chunks
EMBEDDING_MODEL=gemini-embedding-2-preview

# Generation model
GENERATION_MODEL=gemma-4-31b-it

# Judge models
JUDGE_MODEL_A=gemma-3-12b-it
JUDGE_MODEL_B=gemma-3-27b-it

# Release gate
RELEASE_MIN_DELTA=0.05
RELEASE_MIN_HIT_RATE=0.55

# Set to 1 when index already exists
SKIP_INGEST=0
